# Copy to .env locally. Fill secrets on your machine; never paste them into chat.
POSTGRES_DB=sales_agent
POSTGRES_USER=sales_agent
POSTGRES_PASSWORD=sales_agent_demo_password
DATABASE_URL=postgresql+asyncpg://sales_agent:sales_agent_demo_password@db:5432/sales_agent

DEMO_MODE=true
AI_PROVIDER=stub
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=

MAIL_TRANSPORT=file
MAIL_FROM=sales-agent@example.com
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SYNC_ENABLED=false
IMAP_FOLDER=INBOX
IMAP_SENT_FOLDER=[Gmail]/Sent Mail
IMAP_POLL_SECONDS=60
IMAP_BATCH_SIZE=50
IMAP_DAILY_DOWNLOAD_LIMIT_MB=1500
IMAP_MAX_BACKOFF_SECONDS=1800
JOB_LEASE_SECONDS=900
OUTBOX_LEASE_SECONDS=600
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_STARTTLS=false

DINGTALK_TRANSPORT=log
DINGTALK_WEBHOOK_URL=

# Weekly commercial-data gate. Nanjing staff confirm prices and per-product
# inventory for the China-local commercial week before automated quotes send.
COMMERCIAL_GATE_ENABLED=true
COMMERCIAL_DATA_PROVIDER=database
COMMERCIAL_SCOPE=default
COMMERCIAL_TIMEZONE=Asia/Shanghai
COMMERCIAL_OPEN_HOUR=9
# Customer-facing automation and reactivation continue on India business time.
BUSINESS_TIMEZONE=Asia/Kolkata
BUSINESS_OPEN_HOUR=9
COMMERCIAL_REFRESH_CHECK_SECONDS=60
COMMERCIAL_RETRY_MINUTES=15
# Optional future CRM/WMS links. Leave blank to use this application's pages.
COMMERCIAL_UPDATE_URL=
CRM_REVIEW_URL_TEMPLATE=

# Historical-customer reactivation is inert until an administrator creates a
# campaign, selects recipients, and starts it from /admin/reactivation.
REACTIVATION_ENABLED=true
REACTIVATION_CHECK_SECONDS=10
# This is a dedicated cap inside the mailbox-wide hourly/daily limits below.
# Keeping it low reserves capacity for live customer replies.
REACTIVATION_MAX_SENDS_PER_DAY=5
REACTIVATION_DEFAULT_INACTIVE_DAYS=365
REACTIVATION_DEFAULT_SECOND_DAYS=90

SAFE_MODE=true
AUTO_SEND_ENABLED=false
RECIPIENT_ALLOWLIST=internal@example.com
MAX_SENDS_PER_HOUR=5
MAX_SENDS_PER_DAY=20
MIN_SEND_INTERVAL_SECONDS=120
SEND_INTERVAL_JITTER_SECONDS=180
GMAIL_TRANSIENT_COOLDOWN_SECONDS=600
GMAIL_DAILY_COOLDOWN_SECONDS=86400
EMAIL_PREFLIGHT_ENABLED=true
MX_CHECK_ENABLED=true
MX_CACHE_TTL_HOURS=168
MX_LOOKUP_TIMEOUT_SECONDS=5
MX_TEMPORARY_RETRY_MINUTES=30

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-locally
PUBLIC_BASE_URL=http://localhost:8000
RUNTIME_DIR=/app/runtime
CONTENT_DIR=/app/config/content
